        Case "F002": GetVerifyMessage = "CaptchaVerifyParamВЮЪ§ЮЊПе"
        Case "F003": GetVerifyMessage = "CaptchaVerifyParamИёЪНВЛКЯЗЈ"
        Case "F004": GetVerifyMessage = "ВтЪдФЃЪНЃЌХфжУСЫбщжЄВЛЭЈЙ§"
        Case "F005": GetVerifyMessage = "ГЁОАIDВЛКЯЗЈЃЈВЮЪ§вьГЃЃЉ"
        Case "F006": GetVerifyMessage = "ГЁОАIDВЛКЯЗЈЃЈЧАЖЫХфжУДэЮѓЃЉ"
        Case "F008": GetVerifyMessage = "бщжЄЪ§ОнжиИДЬсНЛ"
        Case "F009": GetVerifyMessage = "МьВтЕНащФтЩшБИЛЗОГ"
        Case "F010": GetVerifyMessage = "ЭЌIPЗУЮЪЦЕТЪГЌГіЯожЦ"
        Case "F011": GetVerifyMessage = "ЭЌЩшБИЗУЮЪЦЕТЪГЌГіЯожЦ"
        Case "F012": GetVerifyMessage = "ЗўЮёЖЫSceneIDгыЧАЖЫВЛвЛжТ"
        Case "F013": GetVerifyMessage = "CaptchaVerifyParamШБЩйВЮЪ§"
        Case "F014": GetVerifyMessage = "ЮоГѕЪМЛЏМЧТМ"
        Case "F015": GetVerifyMessage = "бщжЄНЛЛЅВЛЭЈЙ§"
