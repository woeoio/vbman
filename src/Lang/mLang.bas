Attribute VB_Name = "mLang"
Option Explicit

Public LangCollection As New Collection
Public Enum EnumLangMap
    ByID = 0
    ByTag = 1
    ByName = 2
End Enum

Public Property Get LangMap(Field As EnumLangMap, Search As String) As Variant
    If LangCollection.Count = 0 Then LangCollectionAdd
    Dim x As Variant
    For Each x In LangCollection
        If x(Field) = Search Then LangMap = x: Exit Property
    Next
    LangMap = Array("", "", "")
End Property

