' СЌНгЕН Redis ЗўЮёЦї
Public Function Connect(Optional ByVal Server As String = "127.0.0.1", _
    Optional ByVal Port As Long = 6379, _
    Optional ByVal Password As String = "") As Boolean
    On Error GoTo ErrorHandler

    ' ЩшжУВЮЪ§
    m_sHost = Server
    m_lPort = Port
    m_sPassword = Password

    ' ЙиБеЯжгаСЌНг
    If Not m_oSocket Is Nothing Then
        m_oSocket.Close_
        Set m_oSocket = Nothing
    End If

    ' ДДНЈаТСЌНг
    Set m_oSocket = New cWinsock
    m_oSocket.Protocol = wskTCPProtocol

    ' ЪЙгУЭЌВНСЌНг
    If Not m_oSocket.SyncConnect(m_sHost, m_lPort, m_dTimeout * 1000) Then
        LastError = "СЌНгГЌЪБ"
        RaiseEvent OnError(LastError)
        Connect = False
        Exit Function
    End If

    m_bConnected = True

    ' ШчЙћгаУмТы,жДааШЯжЄ
    If LenB(m_sPassword) > 0 Then
        If Not Auth(m_sPassword) Then
            LastError = "ШЯжЄЪЇАм"
            RaiseEvent OnError(LastError)
            Connect = False
            Exit Function
        End If
    End If

    ' ШчЙћжИЖЈСЫЪ§ОнПтЫїв§,ЧаЛЛЪ§ОнПт
    If m_lDbIndex > 0 Then
        Call SelectDb(m_lDbIndex)
    End If

    Connect = True
    Exit Function

ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    Connect = False
End Function

' ЖЯПЊСЌНг
Public Sub DisConnect()
    If Not m_oSocket Is Nothing Then
        On Error Resume Next
        m_oSocket.Close_
        Set m_oSocket = Nothing
        On Error GoTo 0
    End If
    m_bConnected = False
    m_bInTransaction = False
    m_bInPipeline = False
End Sub

' ШЯжЄ
Public Function Auth(ByVal Password As String) As Boolean
    On Error GoTo ErrorHandler
    
    Dim sResp As Variant
    sResp = SendCommand(Array("AUTH", Password))

    If varType(sResp) = vbString Then
        If sResp = "OK" Then
            Auth = True
            Exit Function
        End If
    End If

    Auth = False
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    Auth = False
End Function

' бЁдёЪ§ОнПт
Public Function SelectDb(ByVal Index As Long) As Boolean
    On Error GoTo ErrorHandler
    
    Dim sResp As Variant
    sResp = SendCommand(Array("SELECT", CStr(Index)))

    If varType(sResp) = vbString Then
        If sResp = "OK" Then
            m_lDbIndex = Index
            SelectDb = True
            Exit Function
        End If
    End If

    SelectDb = False
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    SelectDb = False
End Function

