' INFO 命令
Public Function Info(Optional ByVal Section As String = "") As String
    On Error GoTo ErrorHandler
    
    Dim sResp As Variant
    If LenB(Section) > 0 Then
        sResp = SendCommand(Array("INFO", Section))
    Else
        sResp = SendCommand("INFO")
    End If
    
    If IsString(sResp) Then
        Info = sResp
    End If
    
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    Info = ""
End Function

' FLUSHDB 命令
Public Function FlushDb() As Boolean
    On Error GoTo ErrorHandler
    
    Dim sResp As Variant
    sResp = SendCommand("FLUSHDB")
    
    If IsString(sResp) And sResp = "OK" Then
        FlushDb = True
        Exit Function
    End If
    
    FlushDb = False
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    FlushDb = False
End Function

'=========================================================================
' 私有方法
'=========================================================================

' 发送命令并接收响应
Private Function SendCommand(ByVal Command As Variant) As Variant
    If Not m_bConnected Then
        ERR.Raise vbObjectError, MODULE_NAME, "Not connected to Redis server"
    End If
    
    Dim sCmd As String
    sCmd = BuildRedisCommand(Command)
    
    Dim baCmd() As Byte
    baCmd = ToolsUtf8.Encode(sCmd)
    
    ' 发送命令
    m_oSocket.SendData baCmd
    
    ' 接收响应
    Dim sResponse As String
    sResponse = ReceiveResponse()
    
    ' 解析响应
    SendCommand = ParseResp(sResponse)
End Function

' 构建 Redis RESP 协议命令
Private Function BuildRedisCommand(ByVal Command As Variant) As String
    Dim vParts As Variant
    Dim sCmd As String
    Dim i As Long
    
    If IsArray(Command) Then
        vParts = Command
    Else
        vParts = Array(Command)
    End If
    
    ' 数组格式: *<number of elements>\r\n<elements>
    sCmd = "*" & UBound(vParts) + 1 & vbCrLf
    
    For i = LBound(vParts) To UBound(vParts)
        Dim sPart As String
        sPart = CStr(vParts(i))
        ' 批量字符串格式: $<length>\r\n<string>\r\n
        sCmd = sCmd & "$" & Len(sPart) & vbCrLf & sPart & vbCrLf
    Next
    
    BuildRedisCommand = sCmd
End Function

' 接收响应
Private Function ReceiveResponse() As String
    Dim lStartTime As Double
    Dim sBuffer As String
    Dim baData() As Byte
    
    lStartTime = Timer
    sBuffer = ""
    
    Do While (Timer - lStartTime) < m_dTimeout
        If m_oSocket.BytesReceived > 0 Then
            ReDim baData(m_oSocket.BytesReceived - 1)
            m_oSocket.GetData baData
            sBuffer = sBuffer & ToolsUtf8.Decode(baData)
            
            ' 检查是否收到完整响应
            If IsCompleteResp(sBuffer) Then
                Exit Do
            End If
        End If
        DoEvents
    Loop
    
    ReceiveResponse = sBuffer
End Function

' 检查 RESP 响应是否完整
Private Function IsCompleteResp(ByVal Buffer As String) As Boolean
    If LenB(Buffer) = 0 Then
        IsCompleteResp = False
        Exit Function
    End If
    
    Dim sType As String
    sType = Left(Buffer, 1)
    
    Select Case sType
        Case "+", "-", ":"
            ' 简单字符串、错误、整数
            IsCompleteResp = InStr(Buffer, vbCrLf) > 0
        
        Case "$"
            ' 批量字符串
            Dim lCrLf As Long
            lCrLf = InStr(Buffer, vbCrLf)
            If lCrLf > 0 Then
                Dim lLength As Long
                lLength = Val(Mid(Buffer, 2, lCrLf - 2))
                
                If lLength = -1 Then
                    ' null 值
                    IsCompleteResp = True
                Else
                    Dim lExpectedLen As Long
                    lExpectedLen = lCrLf + 2 + lLength + 2
                    IsCompleteResp = Len(Buffer) >= lExpectedLen
                End If
            Else
                IsCompleteResp = False
            End If
        
        Case "*"
            ' 数组
            Dim lCrLf2 As Long
            lCrLf2 = InStr(Buffer, vbCrLf)
            If lCrLf2 > 0 Then
                Dim lCount As Long
                lCount = Val(Mid(Buffer, 2, lCrLf2 - 2))
                
                If lCount = -1 Then
                    ' null 数组
                    IsCompleteResp = True
                ElseIf lCount = 0 Then
                    ' 空数组
                    IsCompleteResp = True
                Else
                    ' 简化处理:假设数组元素都是完整接收的
                    ' 实际应该递归检查每个元素
                    IsCompleteResp = True
                End If
            Else
                IsCompleteResp = False
            End If
        
        Case Else
            IsCompleteResp = True
    End Select
End Function

' 解析 RESP 响应
Private Function ParseResp(ByVal Buffer As String) As Variant
    If LenB(Buffer) = 0 Then
        ParseResp = Array()
        Exit Function
    End If
    
    Dim lPos As Long
    Dim lCrLf As Long
    Dim sType As String
    Dim sLine As String
    
    lPos = 1
    sType = Mid(Buffer, lPos, 1)
    lPos = lPos + 1
    
    Select Case sType
        Case "+"
            ' 简单字符串
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ParseResp = Mid(Buffer, lPos, lCrLf - lPos)
        
        Case "-"
            ' 错误
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ERR.Raise vbObjectError, MODULE_NAME, Mid(Buffer, lPos, lCrLf - lPos)
        
        Case ":"
            ' 整数
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ParseResp = CLng(Mid(Buffer, lPos, lCrLf - lPos))
        
        Case "$"
            ' 批量字符串
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            Dim lLength As Long
            lLength = Val(Mid(Buffer, lPos, lCrLf - lPos))
            
            lPos = lCrLf + 2
            If lLength = -1 Then
                ParseResp = Null
            Else
                ParseResp = Mid(Buffer, lPos, lLength)
                lPos = lPos + lLength + 2
            End If
        
        Case "*"
            ' 数组
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            Dim lCount As Long
            lCount = Val(Mid(Buffer, lPos, lCrLf - lPos))
            
            lPos = lCrLf + 2
            
            If lCount = -1 Then
                ParseResp = Null
            ElseIf lCount = 0 Then
                ParseResp = Array()
            Else
                Dim vArray() As Variant
                ReDim vArray(lCount - 1)
                
                Dim i As Long
                For i = 0 To lCount - 1
                    vArray(i) = ParseResp(Mid(Buffer, lPos))
                    ' 更新位置(简化处理,实际需要计算每个元素的长度)
                    lPos = InStr(lPos, Buffer, vbCrLf) + 2
                    If Mid(Buffer, lPos - 2, 1) = "$" Then
                        Dim lLen As Long
                        lLen = Val(Mid(Buffer, lPos))
                        lPos = lPos + InStr(lPos, Buffer, vbCrLf) + 2 + lLen + 2
                    End If
                Next
                
                ParseResp = vArray
            End If
        
        Case Else
            ParseResp = Buffer
    End Select
End Function

