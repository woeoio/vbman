Private Enum RedisResponseType
    RESP_SIMPLE_STRING = 1                                                      '+'
    RESP_ERROR = 2                                                              '-'
    RESP_INTEGER = 3                                                            ':'
    RESP_BULK_STRING = 4                                                        '$'
    RESP_ARRAY = 5                                                              '*'
End Enum

