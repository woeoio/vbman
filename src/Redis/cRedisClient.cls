Private Sub Class_Initialize()
    m_sHost = "127.0.0.1"
    m_lPort = 6379
    m_sPassword = ""
    m_lDbIndex = 0
    m_dTimeout = 5
    m_bConnected = False
    m_bInTransaction = False
    Set m_oPipeline = New Collection
    m_bInPipeline = False
End Sub

Private Sub Class_Terminate()
    Call Disconnect
    Set m_oPipeline = Nothing
End Sub
