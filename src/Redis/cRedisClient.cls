' ПЊЪМЙмЕРФЃЪН
Public Function PipelineStart() As Boolean
    If m_bInPipeline Then
        m_sLastError = "Already in pipeline mode"
        PipelineStart = False
        Exit Function
    End If
    If m_bInTransaction Then
        m_sLastError = "Cannot start pipeline in transaction"
        PipelineStart = False
        Exit Function
    End If

    m_bInPipeline = True
    m_lPipelineCount = 0
    PipelineStart = True
End Function

' ЫЂаТЙмЕРЃЌЖСШЁЫљгаЯьгІ
Public Function PipelineFlush() As Variant
    On Error GoTo ErrorHandler

    If Not m_bInPipeline Then
        m_sLastError = "Not in pipeline mode"
        PipelineFlush = Array()
        Exit Function
    End If

    If m_lPipelineCount = 0 Then
        m_bInPipeline = False
        PipelineFlush = Array()
        Exit Function
    End If

    Dim vResults() As Variant
    ReDim vResults(m_lPipelineCount - 1) As Variant

    Dim i As Long
    For i = 0 To m_lPipelineCount - 1
        vResults(i) = SafeReadResp()
    Next

    m_bInPipeline = False
    m_lPipelineCount = 0
    PipelineFlush = vResults
    Exit Function

ErrorHandler:
    m_sLastError = ERR.Description
    RaiseEvent OnError(m_sLastError)
    m_bInPipeline = False
    m_lPipelineCount = 0
    PipelineFlush = Array()
End Function

' ШЁЯћЙмЕРЃЈАВШЋЖЯПЊЃЌБмУтЯьгІДэЮЛЃЉ
Public Sub PipelineDiscard()
    If m_bInPipeline Then
        m_bInPipeline = False
        m_lPipelineCount = 0
        Call Disconnect
    End If
End Sub

