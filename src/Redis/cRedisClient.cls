'=========================================================================
' 事务操作
'=========================================================================

' 开始事务
Public Function Multi() As Boolean
    On Error GoTo ErrorHandler
    
    Dim sResp As Variant
    sResp = SendCommand("MULTI")
    
    If IsString(sResp) And sResp = "OK" Then
        m_bInTransaction = True
        Multi = True
        Exit Function
    End If
    
    Multi = False
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    Multi = False
End Function

' 提交事务
Public Function Exec() As Variant
    On Error GoTo ErrorHandler
    
    If Not m_bInTransaction Then
        LastError = "Not in transaction"
        RaiseEvent OnError(LastError)
        Exec = Array()
        Exit Function
    End If
    
    Dim vRet As Variant
    vRet = SendCommand("EXEC")
    
    m_bInTransaction = False
    
    If IsArray(vRet) Then
        Exec = vRet
    Else
        Exec = Array()
    End If
    
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    m_bInTransaction = False
    Exec = Array()
End Function

' 放弃事务
Public Function Discard() As Boolean
    On Error GoTo ErrorHandler
    
    If Not m_bInTransaction Then
        Discard = False
        Exit Function
    End If
    
    Dim sResp As Variant
    sResp = SendCommand("DISCARD")
    
    m_bInTransaction = False
    
    If IsString(sResp) And sResp = "OK" Then
        Discard = True
        Exit Function
    End If
    
    Discard = False
    Exit Function
    
ErrorHandler:
    LastError = ERR.Description
    RaiseEvent OnError(LastError)
    m_bInTransaction = False
    Discard = False
End Function

