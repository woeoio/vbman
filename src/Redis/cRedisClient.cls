                End If
            End If
    End Select

    ReceiveElement = sBuffer
End Function

' МьВщ RESP ЯьгІЪЧЗёЭъећ
Private Function IsCompleteResp(ByVal Buffer As String) As Boolean
    If LenB(Buffer) = 0 Then
        IsCompleteResp = False
        Exit Function
    End If
    
    Dim sType As String
    sType = Left(Buffer, 1)
    
    Select Case sType
        Case "+", "-", ":"
            ' МђЕЅзжЗћДЎЁЂДэЮѓЁЂећЪ§
            IsCompleteResp = InStr(Buffer, vbCrLf) > 0
        
        Case "$"
            ' ХњСПзжЗћДЎ
            Dim lCrLf As Long
            lCrLf = InStr(Buffer, vbCrLf)
            If lCrLf > 0 Then
                Dim lLength As Long
                lLength = Val(Mid(Buffer, 2, lCrLf - 2))
                
                If lLength = -1 Then
                    ' null жЕ
                    IsCompleteResp = True
                Else
                    Dim lExpectedLen As Long
                    lExpectedLen = lCrLf + 2 + lLength + 2
                    IsCompleteResp = Len(Buffer) >= lExpectedLen
                End If
            Else
                IsCompleteResp = False
            End If
        
        Case "*"
            ' Ъ§зщ
            Dim lCrLf2 As Long
            lCrLf2 = InStr(Buffer, vbCrLf)
            If lCrLf2 > 0 Then
                Dim lCount As Long
                lCount = Val(Mid(Buffer, 2, lCrLf2 - 2))
                
                If lCount = -1 Then
                    ' null Ъ§зщ
                    IsCompleteResp = True
                ElseIf lCount = 0 Then
                    ' ПеЪ§зщ
                    IsCompleteResp = True
                Else
                    ' МђЛЏДІРэ:МйЩшЪ§зщдЊЫиЖМЪЧЭъећНгЪеЕФ
                    ' ЪЕМЪгІИУЕнЙщМьВщУПИідЊЫи
                    IsCompleteResp = True
                End If
            Else
                IsCompleteResp = False
            End If
        
        Case Else
            IsCompleteResp = True
    End Select
End Function

' НтЮі RESP ЯьгІ
Private Function ParseResp(ByVal Buffer As String) As Variant
    If LenB(Buffer) = 0 Then
        ParseResp = Array()
        Exit Function
    End If
    
    Dim lPos As Long
    Dim lCrLf As Long
    Dim sType As String
    Dim sLine As String
    
    lPos = 1
    sType = Mid(Buffer, lPos, 1)
    lPos = lPos + 1
    
    Select Case sType
        Case "+"
            ' МђЕЅзжЗћДЎ
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ParseResp = Mid(Buffer, lPos, lCrLf - lPos)
        
        Case "-"
            ' ДэЮѓ
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ERR.Raise vbObjectError, MODULE_NAME, Mid(Buffer, lPos, lCrLf - lPos)
        
        Case ":"
            ' ећЪ§
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            ParseResp = CLng(Mid(Buffer, lPos, lCrLf - lPos))
        
        Case "$"
            ' ХњСПзжЗћДЎ
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            Dim lLength As Long
            lLength = Val(Mid(Buffer, lPos, lCrLf - lPos))
            
            lPos = lCrLf + 2
            If lLength = -1 Then
                ParseResp = Null
            Else
                ParseResp = Mid(Buffer, lPos, lLength)
                lPos = lPos + lLength + 2
            End If
        
        Case "*"
            ' Ъ§зщ
            lCrLf = InStr(lPos, Buffer, vbCrLf)
            Dim lCount As Long
            lCount = Val(Mid(Buffer, lPos, lCrLf - lPos))
            
            lPos = lCrLf + 2
            
            If lCount = -1 Then
                ParseResp = Null
            ElseIf lCount = 0 Then
                ParseResp = Array()
            Else
                Dim vArray() As Variant
                ReDim vArray(lCount - 1)
                
                Dim i As Long
                For i = 0 To lCount - 1
                    vArray(i) = ParseResp(Mid(Buffer, lPos))
                    ' ИќаТЮЛжУ(МђЛЏДІРэ,ЪЕМЪашвЊМЦЫуУПИідЊЫиЕФГЄЖШ)
                    lPos = InStr(lPos, Buffer, vbCrLf) + 2
                    If Mid(Buffer, lPos - 2, 1) = "$" Then
                        Dim lLen As Long
                        lLen = Val(Mid(Buffer, lPos))
                        lPos = lPos + InStr(lPos, Buffer, vbCrLf) + 2 + lLen + 2
                    End If
                Next
                
                ParseResp = vArray
            End If
        
        Case Else
            ParseResp = Buffer
    End Select
End Function

