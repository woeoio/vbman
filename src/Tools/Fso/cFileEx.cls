VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
  Persistable = 0  'NotPersistable
  DataBindingBehavior = 0  'vbNone
  DataSourceBehavior  = 0  'vbNone
  MTSTransactionMode  = 0  'NotAnMTSObject
END
Attribute VB_Name = "cFileEx"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = True
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = True
Option Explicit

' ============================================================
' ИпМЖЮФМўВйзїРр (Open гяОфЪЕЯж)
'   - ЪЙгУ VB д­Щњ Open гяОфЃЌМцШнадКУ
'   - вЛИіЪЕР§ЭЌвЛЪБМфжЛФмВйзївЛИіЮФМў
'   - ЖСШЁФкШнЯШНјШыФкВПЛКГхЧјЃЌдйЭЈЙ§ ReturnXXX ЬсШЁ
'   - НгПкгы cFileIO БЃГжвЛжТ
' ============================================================

' --- Win32 API ЩљУї (гУгкБрТызЊЛЛКЭФкДцВйзї) ---
Private Declare Function MultiByteToWideChar Lib "kernel32" (ByVal CodePage As Long, ByVal dwFlags As Long, ByRef lpMultiByteStr As Any, ByVal cchMultiByte As Long, ByVal lpWideCharStr As Long, ByVal cchWideChar As Long) As Long
Private Declare Function WideCharToMultiByte Lib "kernel32" (ByVal CodePage As Long, ByVal dwFlags As Long, ByVal lpWideCharStr As Long, ByVal cchWideChar As Long, ByRef lpMultiByteStr As Any, ByVal cchMultiByte As Long, ByVal lpDefaultChar As String, ByVal lpUsedDefaultChar As Long) As Long
Private Declare Sub CopyMemory Lib "kernel32" Alias "RtlMoveMemory" (Destination As Any, Source As Any, ByVal Length As Long)

' --- ГЃСП ---
Private Const CP_UTF8                   As Long = 65001
Private Const CP_ACP                    As Long = 0

' --- ГЩдББфСП ---
Private m_FileNo        As Integer      ' ЮФМўКХ
Private m_Path          As String       ' ДђПЊЕФЮФМўТЗОЖ
Private m_Buffer()      As Byte         ' ФкВПЪ§ОнЛКГхЧј
Private m_IsOpen        As Boolean      ' ЪЧЗёвбДђПЊ
Private m_LastError     As String       ' зюКѓвЛДЮДэЮѓаХЯЂ
Private m_AccessMode    As String       ' ЕБЧАЗУЮЪФЃЪН R/W/RW

' ============================================================
' Ъєад
' ============================================================

Public Property Get IsOpen() As Boolean
    IsOpen = m_IsOpen
End Property

Public Property Get FilePath() As String
    FilePath = m_Path
End Property

Public Property Get LastError() As String
    LastError = m_LastError
End Property

' ЮФМўДѓаЁ (ЗЕЛи Currency РраЭЃЌЕЅЮЛзжНкЃЌМцШн cFileIO НгПк)
Public Property Get FileSize() As Currency
    If Not m_IsOpen Then ERR.Raise 53, "cFileEx.FileSize", "ЮФМўЮДДђПЊ"
    Dim fLen As Currency
    fLen = FileLen(m_Path)
    FileSize = fLen
End Property

' ЕБЧАЛКГхЧјзжНкЪ§
Public Property Get BufferSize() As Long
    If Not IsBufferValid Then
        BufferSize = 0
    Else
        BufferSize = UBound(m_Buffer) - LBound(m_Buffer) + 1
    End If
End Property

' ============================================================
' ЮФМўДђПЊ/ЙиБе
' ============================================================

' ДђПЊЮФМўЃЌЗЕЛи Me жЇГжСДЪНЕїгУ
' AccessMode: "R"=жЛЖС, "W"=жЛаД, "RW"=ЖСаД(ФЌШЯ)
Public Function OpenFile(ByVal FilePath As String, Optional ByVal AccessMode As String = "RW") As cFileEx
    CloseFile
    
    m_AccessMode = UCase$(Trim$(AccessMode))
    
    ' ЛёШЁПЩгУЮФМўКХ
    m_FileNo = FreeFile
    
    On Error GoTo OpenError
    
    Select Case m_AccessMode
        Case "R"
            ' жЛЖСФЃЪН - ЮФМўБиаыДцдк
            If Dir(FilePath, vbNormal) = "" Then
                ERR.Raise 53, "cFileEx.OpenFile", "ЮФМўВЛДцдк: " & FilePath
            End If
            Open FilePath For Binary Access Read As #m_FileNo
            
        Case "W"
            ' жЛаДФЃЪН - ДДНЈЛђИВИЧ
            Open FilePath For Output As #m_FileNo
            Close #m_FileNo
            ' жиаТвд Binary ДђПЊгУгкаДШы
            Open FilePath For Binary Access Write As #m_FileNo
            
        Case Else
            ' ЖСаДФЃЪН (ФЌШЯ)
            If Dir(FilePath, vbNormal) = "" Then
                ' ЮФМўВЛДцдкЃЌДДНЈаТЮФМў
                Open FilePath For Output As #m_FileNo
                Close #m_FileNo
            End If
            Open FilePath For Binary Access Read Write As #m_FileNo
            m_AccessMode = "RW"
    End Select
    
    m_Path = FilePath
    m_IsOpen = True
    m_LastError = ""
    Set OpenFile = Me
    Exit Function
    
OpenError:
    m_LastError = "ЮоЗЈДђПЊЮФМў: " & FilePath & " - " & ERR.Description
    ERR.Raise ERR.Number, "cFileEx.OpenFile", m_LastError
End Function

Public Sub CloseFile()
    If m_IsOpen And m_FileNo > 0 Then
        On Error Resume Next
        Close #m_FileNo
        On Error GoTo 0
        m_FileNo = 0
        m_IsOpen = False
        m_Path = ""
        m_AccessMode = ""
    End If
End Sub

' ============================================================
' ЛКГхЧјВйзї
' ============================================================

' ЧхПеФкВПЛКГхЧј
Public Function ClearBuffer() As cFileEx
    Erase m_Buffer
    Set ClearBuffer = Me
End Function

' гУЭтВПзжНкЪ§зщЬюГфЛКГхЧјЃЌЗЕЛи Me
Public Function SetBuffer(Data() As Byte) As cFileEx
    m_Buffer = Data
    Set SetBuffer = Me
End Function

' зЗМгзжНкЕНЛКГхЧј
Public Function AppendBuffer(Data() As Byte) As cFileEx
    Dim oldLen As Long, newLen As Long, addLen As Long
    oldLen = UBound(m_Buffer) + 1
    addLen = UBound(Data) + 1
    If addLen <= 0 Then
        Set AppendBuffer = Me
        Exit Function
    End If
    newLen = oldLen + addLen
    ReDim Preserve m_Buffer(newLen - 1)
    CopyMemory m_Buffer(oldLen), Data(0), addLen
    Set AppendBuffer = Me
End Function

' гУзжЗћДЎЬюГфЛКГхЧјЃЈФЌШЯ UTF-8ЃЉЃЌЗЕЛи Me
Public Function SetBufferText(ByVal Text As String, Optional ByVal CharSet As String = "UTF-8") As cFileEx
    m_Buffer = StringToBytes(Text, CharSet)
    Set SetBufferText = Me
End Function

' ============================================================
' Ъ§ОнЖСШЁЃЈЖСШыФкВПЛКГхЧјЃЉ
' ============================================================

' НЋЮФМўжИЖЈЗЖЮЇЖСШыФкВПЛКГхЧјЃЌЗЕЛи Me жЇГжСДЪНЕїгУЁЃ
'   StartPos / EndPos ЮЊ 0-based зжНкЦЋвЦЃЛДЋ -1 БэЪОЪЙгУФЌШЯжЕЁЃ
'   StartPos = -1 : ДгЮФМўПЊЭЗЃЈЕк 0 зжНкЃЉПЊЪМ
'   EndPos   = -1 : ЖСЕНЮФМўзюКѓвЛИізжНк
Public Function ReadData(Optional ByVal StartPos As Long = -1, Optional ByVal EndPos As Long = -1) As cFileEx
    If Not m_IsOpen Then ERR.Raise 53, "cFileEx.ReadData", "ЮФМўЮДДђПЊ"
    
    Dim fLen As Long
    fLen = LOF(m_FileNo)
    If fLen <= 0 Then
        Erase m_Buffer
        Set ReadData = Me
        Exit Function
    End If
    
    Dim sPos As Long, ePos As Long
    sPos = IIf(StartPos < 0, 0, StartPos)
    If sPos < 0 Then sPos = 0
    If sPos >= fLen Then sPos = fLen - 1
    
    ePos = IIf(EndPos < 0, fLen - 1, EndPos)
    If ePos >= fLen Then ePos = fLen - 1
    If ePos < sPos Then ePos = sPos
    
    Dim rLen As Long
    rLen = ePos - sPos + 1
    
    ' Open гяОфЯожЦЃКвЛДЮзюЖрЖСШЁ 2GB
    If rLen > 2147483647 Then
        m_LastError = "ЕЅДЮЖСШЁВЛФмГЌЙ§ 2GB"
        ERR.Raise 6, "cFileEx.ReadData", m_LastError
    End If
    
    ' ЖЈЮЛЕНПЊЪМЮЛжУВЂЖСШЁ
    ReDim m_Buffer(0 To rLen - 1)
    
    On Error GoTo ReadError
    
    ' ЪЙгУ Get гяОфЖСШЁЖўНјжЦЪ§Он
    Get #m_FileNo, sPos + 1, m_Buffer
    
    m_LastError = ""
    Set ReadData = Me
    Exit Function
    
ReadError:
    m_LastError = "ЖСШЁЮФМўЪЇАм: " & ERR.Description
    ERR.Raise 5, "cFileEx.ReadData", m_LastError
End Function

' ============================================================
' Ъ§ОнЗЕЛиЃЈДгФкВПЛКГхЧјЬсШЁЃЉ
' ============================================================

' ЗЕЛиЮФБОЃЌCharSet ФЌШЯ UTF-8
Public Function ReturnText(Optional ByVal CharSet As String = "UTF-8") As String
    If Not IsBufferValid Then
        ReturnText = ""
        Exit Function
    End If
    ReturnText = BytesToString(m_Buffer, CharSet)
End Function

' ЗЕЛизжНкЪ§зщЃЈИББОЃЉ
Public Function ReturnBytes() As Byte()
    If Not IsBufferValid Then
        Dim emptyBuf() As Byte
        ReturnBytes = emptyBuf
        Exit Function
    End If
    ReturnBytes = m_Buffer
End Function

' ЗЕЛи Base64 БрТызжЗћДЎ
Public Function ReturnBase64() As String
    If Not IsBufferValid Then
        ReturnBase64 = ""
        Exit Function
    End If
    ReturnBase64 = ToolsBase64.BytesToBase64(m_Buffer)
End Function

' ЗЕЛи Hex БрТызжЗћДЎЃЌПЩбЁЗжИєЗћЃЈФЌШЯПеИёЃЌУП2зжЗћвЛзщЃЉ
Public Function ReturnHex(Optional ByVal Separator As String = " ") As String
    If Not IsBufferValid Then
        ReturnHex = ""
        Exit Function
    End If
    
    Dim i As Long, ub As Long
    Dim result As String
    Dim hexByte As String
    
    ub = UBound(m_Buffer)
    result = ""
    
    For i = LBound(m_Buffer) To ub
        ' ИёЪНЛЏЮЊ2ЮЛЪЎСљНјжЦЃЌВЛзуВЙ0
        hexByte = Right$("0" & Hex$(m_Buffer(i)), 2)
        result = result & hexByte
        ' ЗЧзюКѓвЛИізжНкЪБЬэМгЗжИєЗћ
        If i < ub Then
            result = result & Separator
        End If
    Next i
    
    ReturnHex = result
End Function

' ЗЕЛиЖўНјжЦзжЗћДЎЃЌПЩбЁЗжИєЗћЃЈФЌШЯПеИёЃЌУП8зжЗћвЛзщЃЉ
Public Function ReturnBinString(Optional ByVal Separator As String = " ") As String
    If Not IsBufferValid Then
        ReturnBinString = ""
        Exit Function
    End If
    
    Dim i As Long, j As Long, ub As Long
    Dim result As String
    Dim binByte As String
    Dim b As Byte
    
    ub = UBound(m_Buffer)
    result = ""
    
    For i = LBound(m_Buffer) To ub
        b = m_Buffer(i)
        binByte = ""
        ' НЋзжНкзЊЛЛЮЊ8ЮЛЖўНјжЦ
        For j = 7 To 0 Step -1
            If (b And (2 ^ j)) <> 0 Then
                binByte = binByte & "1"
            Else
                binByte = binByte & "0"
            End If
        Next j
        result = result & binByte
        ' ЗЧзюКѓвЛИізжНкЪБЬэМгЗжИєЗћ
        If i < ub Then
            result = result & Separator
        End If
    Next i
    
    ReturnBinString = result
End Function

' МьВщЛКГхЧјЪЧЗёгааЇЃЈгаЪ§ОнЃЉ
Private Function IsBufferValid() As Boolean
    On Error Resume Next
    Dim lb As Long
    lb = LBound(m_Buffer)
    If ERR.Number <> 0 Then
        IsBufferValid = False
        ERR.Clear
    Else
        IsBufferValid = (UBound(m_Buffer) >= lb)
    End If
    On Error GoTo 0
End Function

' ============================================================
' Ъ§ОнаДШыЃЈДгФкВПЛКГхЧјаДШыЮФМўЃЉ
' ============================================================

' НЋФкВПЛКГхЧјаДШыЮФМўЁЃ
'   FilePath : ФПБъТЗОЖЃЌЮДЬсЙЉдђЪЙгУ OpenFile ЛКДцЕФТЗОЖ
'   IsAppend : False=ИВИЧ(ФЌШЯ), True=зЗМгЕНЮФМўФЉЮВ
Public Function SaveData(Optional ByVal FilePath As String, Optional ByVal IsAppend As Boolean = False) As cFileEx
    Dim targetPath As String
    targetPath = IIf(Len(FilePath) > 0, FilePath, m_Path)
    If Len(targetPath) = 0 Then
        m_LastError = "ЮДЬсЙЉЮФМўТЗОЖ"
        ERR.Raise 5, "cFileEx.SaveData", m_LastError
    End If
    
    Dim hFile As Integer
    Dim needClose As Boolean
    
    On Error GoTo SaveError
    
    If targetPath = m_Path And m_IsOpen Then
        ' аДШыЕБЧАДђПЊЕФЮФМў
        hFile = m_FileNo
        needClose = False
    Else
        ' ДђПЊФПБъЮФМў
        hFile = FreeFile
        If IsAppend And Dir(targetPath, vbNormal) <> "" Then
            ' зЗМгФЃЪНЧвЮФМўДцдк
            Open targetPath For Binary Access Read Write As #hFile
        Else
            ' ИВИЧФЃЪНЛђаТНЈЮФМў
            Open targetPath For Output As #hFile
            Close #hFile
            Open targetPath For Binary Access Write As #hFile
        End If
        needClose = True
    End If
    
    ' зЗМгФЃЪНЃКЖЈЮЛЕНЮФМўФЉЮВ
    If IsAppend Then
        Seek #hFile, LOF(hFile) + 1
    ElseIf needClose Then
        ' аТНЈЮФМўЃЌДгЭЗПЊЪМаД
        Seek #hFile, 1
    End If
    
    ' аДШыЛКГхЧј
    If IsBufferValid Then
        Put #hFile, , m_Buffer
    End If
    
    If needClose Then
        Close #hFile
    End If
    
    m_LastError = ""
    Set SaveData = Me
    Exit Function
    
SaveError:
    If needClose Then On Error Resume Next: Close #hFile: On Error GoTo 0
    m_LastError = "аДШыЮФМўЪЇАм: " & ERR.Description
    ERR.Raise 5, "cFileEx.SaveData", m_LastError
End Function

' ============================================================
' ИЈжњКЏЪ§
' ============================================================

' зжНкЪ§зщ -> зжЗћДЎЃЈжЇГж UTF-8 / ANSI / UTF-16LEЃЉ
Private Function BytesToString(ByRef b() As Byte, ByVal CharSet As String) As String
    Dim lb As Long: lb = LBound(b)
    Dim cnt As Long: cnt = UBound(b) - lb + 1
    If cnt <= 0 Then Exit Function
    
    Select Case LCase$(Trim$(CharSet))
        Case "utf-8", "utf8"
            ' МьВтВЂЬјЙ§ BOM
            Dim startIdx As Long: startIdx = lb
            If cnt >= 3 Then
                If b(lb) = &HEF And b(lb + 1) = &HBB And b(lb + 2) = &HBF Then
                    startIdx = lb + 3
                    cnt = cnt - 3
                End If
            End If
            If cnt > 0 Then
                Dim wlen As Long
                wlen = MultiByteToWideChar(CP_UTF8, 0, b(startIdx), cnt, 0, 0)
                If wlen > 0 Then
                    BytesToString = String$(wlen, vbNullChar)
                    MultiByteToWideChar CP_UTF8, 0, b(startIdx), cnt, StrPtr(BytesToString), wlen
                End If
            End If
            
        Case "utf-16", "utf-16le", "utf16", "unicode"
            ' МьВтВЂЬјЙ§ BOM
            startIdx = lb
            If cnt >= 2 Then
                If b(lb) = &HFF And b(lb + 1) = &HFE Then
                    startIdx = lb + 2
                    cnt = cnt - 2
                End If
            End If
            If cnt > 0 Then
                BytesToString = b
            End If
            
        Case Else ' ANSI / ЯЕЭГФЌШЯБрТы
            wlen = MultiByteToWideChar(CP_ACP, 0, b(lb), cnt, 0, 0)
            If wlen > 0 Then
                BytesToString = String$(wlen, vbNullChar)
                MultiByteToWideChar CP_ACP, 0, b(lb), cnt, StrPtr(BytesToString), wlen
            End If
    End Select
End Function

' зжЗћДЎ -> зжНкЪ§зщЃЈжЇГж UTF-8 / ANSI / UTF-16LEЃЉ
Private Function StringToBytes(ByVal s As String, ByVal CharSet As String) As Byte()
    Dim b() As Byte
    If Len(s) = 0 Then
        StringToBytes = b
        Exit Function
    End If
    
    Select Case LCase$(Trim$(CharSet))
        Case "utf-8", "utf8"
            Dim blen As Long
            blen = WideCharToMultiByte(CP_UTF8, 0, StrPtr(s), Len(s), ByVal vbNullString, 0, vbNullString, 0)
            If blen > 0 Then
                ReDim b(blen - 1)
                WideCharToMultiByte CP_UTF8, 0, StrPtr(s), Len(s), b(0), blen, vbNullString, 0
            End If
            
        Case "utf-16", "utf-16le", "utf16", "unicode"
            b = s
            
        Case Else ' ANSI
            blen = WideCharToMultiByte(CP_ACP, 0, StrPtr(s), Len(s), ByVal vbNullString, 0, vbNullString, 0)
            If blen > 0 Then
                ReDim b(blen - 1)
                WideCharToMultiByte CP_ACP, 0, StrPtr(s), Len(s), b(0), blen, vbNullString, 0
            End If
    End Select
    StringToBytes = b
End Function

Private Sub Class_Terminate()
    CloseFile
End Sub
